# Required environment variables for MezoShop backend

# Gemini API key for the AI chat agent
GEMINI_API_KEY=your_gemini_api_key_here

# Merchant wallet address on Mezo Testnet (receives MUSD payments)
MERCHANT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Frontend origin for CORS (e.g. http://localhost:5173 in development)
FRONTEND_ORIGIN=http://localhost:5173

# Server port (optional, defaults to 3001)
PORT=3001

# Lending contract address (deployed MezoLending.sol on Mezo testnet)
LENDING_CONTRACT_ADDRESS=0x_deployed_contract_address

# Private key for the backend signer that calls borrow()/repay() on-chain
LENDING_SIGNER_PRIVATE_KEY=0x_signer_private_key
